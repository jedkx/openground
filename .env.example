# OpenGround — copy to .env for local tools (optional). Uvicorn does not load .env by default.
# OPENGROUND_TELEMETRY_MODE=sim
# OPENGROUND_MILESTONE_TIMELINE_PATH=
# OPENGROUND_ISS_API_URL=https://api.wheretheiss.at/v1/satellites/25544
# OPENGROUND_SCENARIO=nominal
# OPENGROUND_TELEMETRY_HZ=1.0
# OPENGROUND_LINK_DROP_PROB=0.08
# OPENGROUND_HISTORY_MAX=5000
# OPENGROUND_LOST_TIMEOUT_S=5.0
# OPENGROUND_LOG_LEVEL=INFO
# OPENGROUND_STATIC_DIR=static
# OPENGROUND_OPENMCT_DIST=node_modules/openmct/dist
